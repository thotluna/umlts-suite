config {
  direction: "top-bottom"
}

class Invoice {
  subtotal: Real
  taxRate: Real = 0.16
  
  // Propiedad derivada (calculada)
  / total: Real
  
  // Atributo privado con getter derivado
  - _items: LineItem[*]
  / itemsCount: Integer {readonly}
}

class LineItem {
  product: String
  quantity: Integer
  unitPrice: Real
  / lineTotal: Real
}

Invoice >* LineItem[1..*]
